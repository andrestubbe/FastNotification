<?xml version="1.0" encoding="utf-8"?>
<!--
  Sparse Package Manifest for FastNotification
  
  This manifest creates a "Package Identity" for your Desktop App
  without packing it into an MSIX container.
  
  The app stays at its installation location (e.g., C:\Program Files\FastNotification)
  but gets access to Windows features like Toast Notifications.
  
  CUSTOMIZE:
  1. Identity Name (must be unique)
  2. Identity Publisher (must match certificate)
  3. Identity Version
  4. DisplayName
  5. Executable Name (your main program)
  6. Logo paths (Assets folder)
  
  See WINDOWS_NOTIFICATION_GUIDE.md for details.
-->
<Package 
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap10">

  <Identity 
    Name="AndreStubbe.FastNotification" 
    Publisher="CN=AndreStubbe" 
    Version="1.0.0.0" 
    ProcessorArchitecture="neutral" />

  <Properties>
    <DisplayName>FastNotification</DisplayName>
    <PublisherDisplayName>Andre Stubbe</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
    <!-- Allows access to files outside the package -->
    <uap10:AllowExternalContent>true</uap10:AllowExternalContent>
  </Properties>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Capabilities>
    <!-- Allows full Win32 app functionality -->
    <rescap:Capability Name="runFullTrust" />
    <!-- Prevents virtualization (file and registry access remains normal) -->
    <rescap:Capability Name="unvirtualizedResources"/>
  </Capabilities>

  <Applications>
    <Application 
      Id="FastNotification"
      Executable="FastNotification.exe"
      uap10:TrustLevel="mediumIL"
      uap10:RuntimeBehavior="win32App">
      
      <!-- Visual elements for start menu and taskbar -->
      <uap:VisualElements 
        AppListEntry="none"
        DisplayName="FastNotification" 
        Description="Native Windows Toast Notifications for Java" 
        BackgroundColor="transparent" 
        Square150x150Logo="Assets\Square150x150Logo.png" 
        Square44x44Logo="Assets\Square44x44Logo.png" />

      <!-- 
        COM Toast Extensions (only if you use WinRT notifications with actions)
        See FastNotification.cpp for WinRT implementation
      -->
      <!--
      <Extensions>
        <uap:Extension Category="windows.protocol">
          <uap:Protocol Name="fastnotification" />
        </uap:Extension>
      </Extensions>
      -->
      
    </Application>
  </Applications>
</Package>
